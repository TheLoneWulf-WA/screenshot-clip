#!/bin/zsh

# screenshot-clip: Auto-copy screenshots to clipboard
# https://github.com/TheLoneWulf-WA/screenshot-clip

WATCH_DIR="${SCREENSHOT_CLIP_DIR:-$HOME/Desktop}"
SLEEP_DURATION="${SCREENSHOT_CLIP_DELAY:-0.1}"

if ! command -v fswatch &> /dev/null; then
    echo "Error: fswatch is required. Install it with: brew install fswatch"
    exit 1
fi

echo "screenshot-clip: Watching $WATCH_DIR for new screenshots..."

fswatch -0 --event Created "$WATCH_DIR" | while IFS= read -r -d '' file; do
    if [[ "$file" == *.png ]]; then
        sleep "$SLEEP_DURATION"
        osascript -e "set the clipboard to (read (POSIX file \"$file\") as «class PNGf»)" 2>/dev/null
        if [[ $? -eq 0 ]]; then
            echo "Copied to clipboard: $(basename "$file")"
        else
            echo "Failed to copy: $(basename "$file")"
        fi
    fi
done
