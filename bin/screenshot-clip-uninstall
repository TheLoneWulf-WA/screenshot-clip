#!/bin/zsh

# screenshot-clip uninstaller
# Stops and removes the launchd agent

PLIST_NAME="com.screenshotclip.agent"
PLIST_PATH="$HOME/Library/LaunchAgents/$PLIST_NAME.plist"

if [[ -f "$PLIST_PATH" ]]; then
    launchctl unload "$PLIST_PATH" 2>/dev/null || true
    rm "$PLIST_PATH"
    echo "screenshot-clip stopped and uninstalled."
else
    echo "screenshot-clip is not installed."
fi
